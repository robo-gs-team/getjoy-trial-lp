          {%- assign proof_parts = proof_text | split: '|' -%}
          {%- for part in proof_parts -%}
            <span class="t16-proof-dot">&middot;</span>
            <span class="t16-proof-stat">{{ part | strip }}</span>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- comment -%} Title {%- endcomment -%}
      <h1 class="t16-product-h1">
        {%- if eyebrow != blank -%}<span class="t16-product-h1-offer">{{ eyebrow }}</span>{%- endif -%}
        <span class="t16-product-h1-value">
          {%- if heading != blank -%}{{ heading }}{%- else -%}{{ product.title }}{%- endif -%}
        </span>
      </h1>
      {%- if subtitle != blank -%}<p class="t16-product-sub">{{ subtitle }}</p>{%- endif -%}
      {%- if pitch != blank -%}<div class="t16-product-pitch">{{ pitch }}</div>{%- endif -%}

      {%- comment -%} ── SUBSCRIPTION SELECTOR ── {%- endcomment -%}

      {%- if step_1_label != blank -%}
        <div class="t16-field-label">{{ step_1_label }}</div>
      {%- endif -%}

      {%- comment -%} Flavor {%- endcomment -%}
      <div class="t32-flavor-row" id="t32FlavorRow">
        {%- for variant in product.variants -%}
          <button
            class="t32-flavor-btn{% if variant == current_variant %} t32-active{% endif %}"
