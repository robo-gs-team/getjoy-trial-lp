              Sold Out
            {%- endif -%}
          </span>
          <svg class="t16-cta-arrow" width="18" height="13" viewBox="0 0 18 13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M1 6.5H17M17 6.5L11 1M17 6.5L11 12" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      {%- endform -%}

      {%- comment -%} Guarantee {%- endcomment -%}
      <div class="t32-guarantee-box">
        <div class="t32-guarantee-title">30-Day Money-Back Guarantee</div>
        <div class="t32-guarantee-sub">Not a hit? We refund every penny — no questions, no hoops, no hassle.</div>
      </div>

      {%- comment -%} FAQ — mobile only (right column) {%- endcomment -%}
      <div class="t16-faq t16-faq--buy">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' -%}
            <div class="t16-faq-item" {{ block.shopify_attributes }}>
              <button class="t16-faq-btn" aria-expanded="false">
                {{ block.settings.question }}
                <svg class="t16-faq-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 8 10 13 15 8"/></svg>
              </button>
              <div class="t16-faq-body"><div class="t16-faq-body-inner">{{ block.settings.answer }}</div></div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>{%- comment -%} /buy-col {%- endcomment -%}

  </div>{%- comment -%} /hero-inner {%- endcomment -%}
</section>

{%- comment -%} Sticky ATC bar {%- endcomment -%}
<div class="t16-atc-bar" id="fdr32ozAtcBar">
  <div class="t16-atc-inner">
    <div class="t16-atc-left">
      {%- if product.featured_image -%}
        <img class="t16-atc-icon" src="{{ product.featured_image | image_url: width: 72 }}" alt="{{ product.title | escape }}" width="36" height="36" loading="lazy">
      {%- endif -%}
      <div class="t16-atc-text">
        <div class="t16-atc-name">{{ product.title }} <span class="t16-atc-name-price" id="t32AtcPrice"></span></div>
        <div class="t16-atc-desc" id="t32AtcDesc">Subscribe &amp; Save · 50% off first order</div>
      </div>
    </div>
    <div class="t16-atc-spacer"></div>
    <div class="t16-atc-flavors" id="t32AtcFlavors">
      {%- for variant in product.variants -%}
        <button
          class="t16-atc-fpill{% if variant == current_variant %} active{% endif %}"
          data-variant-id="{{ variant.id }}"
          data-flavor="{{ variant.option1 | downcase }}"
          type="button"
        >
          <span class="t16-atc-fdot" style="background:{%- if variant.option1 == 'Chicken' -%}#5EDBFF{%- elsif variant.option1 == 'Beef' -%}#FFAF00{%- else -%}#00CC3B{%- endif -%}"></span>
          {{ variant.option1 }}
        </button>
      {%- endfor -%}
    </div>
    <button type="button" class="t16-atc-btn" id="fdr32ozAtcBtn">
      <span class="t16-atc-btn-d" id="t32AtcBtnText">{{ cta_text | default: 'Add to Cart' }}</span>
      <span class="t16-atc-btn-m">Add</span>
    </button>
  </div>
</div>

<script defer>
(function() {
  var SECTION_ID  = {{ section.id | json }};
  var SECTION_SEL = '#shopify-section-' + SECTION_ID + ' ';

  /* ── Liquid-injected data ── */
  var VARIANTS = {};
  {%- for variant in product.variants -%}
    VARIANTS[{{ variant.option1 | downcase | json }}] = {
      id: {{ variant.id }},
      imageId: {{ variant.featured_image.id | default: '' | json }}
    };
  {%- endfor -%}

  var PER_BAG     = {{ product.variants.first.price | divided_by: 100.0 }};
  var FIRST_OFF   = 0.50;
  var SELLING_PLAN_ID = {{ selling_plan_id | default: '' | json }};

  /* ── Selector state ── */
  var state = {
    flavor: {{ current_variant.option1 | downcase | json }},
    age: 'adult',
    size: 's',
    plan: 'sub'
  };

  /* ── Size / feeding data (calibrated from GetJoy feeding guide) ── */
  var SIZES = {
    s:  { adult: 2,  puppy: 4,  days: { adult: 27, puppy: 28 } },
    ms: { adult: 4,  puppy: 8,  days: { adult: 28, puppy: 28 } },
    m:  { adult: 6,  puppy: 13, days: { adult: 28, puppy: 28 } },
    l:  { adult: 8,  puppy: 15, days: { adult: 29, puppy: 29 } },
    xl: { adult: 10, puppy: 22, days: { adult: 30, puppy: 30 } }
  };

  /* ── Feeding guide data per flavor ── */
  var FG_DATA = {
    chicken: [
      ['5 lbs',  '½',   '1.3', '1',   '2.6'],
      ['10 lbs', '¾',   '1.9', '1½', '3.9'],
      ['15 lbs', '1',   '2.6', '2',   '5.2'],
      ['20 lbs', '1¼', '3.2', '2½', '6.5', 'hl'],
      ['30 lbs', '1¾', '4.5', '3½', '9.0'],
      ['40 lbs', '2¼', '5.8', '4½', '11.6'],
      ['50 lbs', '2¾', '7.1', '5½', '14.2', 'hl'],
      ['60 lbs', '3',   '7.7', '6',   '15.5'],
      ['70 lbs', '3½', '9.0', 'max', null, 'hl'],
      ['80 lbs', '3¾', '9.7', null, null],
      ['90 lbs', '4¼', '11.0', null, null],
      ['100 lbs','4½', '11.6', null, null]
    ],
    beef: [
      ['5 lbs',  '½',   '1.4', '1',   '2.8'],
      ['10 lbs', '¾',   '2.0', '1½', '4.1'],
      ['15 lbs', '1',   '2.7', '2',   '5.4'],
      ['20 lbs', '1¼', '3.4', '2½', '6.8', 'hl'],
      ['30 lbs', '1¾', '4.7', '3½', '9.4'],
      ['40 lbs', '2¼', '6.1', '4½', '12.1'],
      ['50 lbs', '2¾', '7.4', '5½', '14.8', 'hl'],
      ['60 lbs', '3¼', '8.4', '6',   '16.2'],
      ['70 lbs', '3½', '9.4', 'max', null, 'hl'],
      ['80 lbs', '4',   '10.4', null, null],
      ['90 lbs', '4½', '11.7', null, null],
      ['100 lbs','4¾', '12.3', null, null]
    ]
  };
  var fgFlavor = 'chicken';

  function fmt(n) { return '$' + n.toFixed(2); }

  /* ── Render pricing ── */
  function render() {
    var tier    = SIZES[state.size];
    var bags    = tier[state.age];
    var days    = tier.days[state.age];
    var regular = bags * PER_BAG;
    var first   = regular * (1 - FIRST_OFF);
    var meals   = days * 2;

    /* Size/days meta */
    var el = document.getElementById('t32SizeMeta');
    if (el) el.textContent = bags + ' bag' + (bags > 1 ? 's' : '') + ' · lasts your dog ~' + days + ' days';

    /* Subscribe card */
    var pNow  = document.getElementById('t32PriceNow');
    var pWas  = document.getElementById('t32PriceWas');
    var pMeal = document.getElementById('t32PriceMeal');
    if (pNow)  pNow.textContent  = fmt(first);
    if (pWas)  pWas.textContent  = fmt(regular);
    if (pMeal) pMeal.textContent = fmt(first / meals) + '/meal';

    /* Buy once */
    var oPrice = document.getElementById('t32OncePriceAmt');
    var oMeal  = document.getElementById('t32OnceMeal');
    if (oPrice) oPrice.textContent = fmt(regular);
    if (oMeal)  oMeal.textContent  = fmt(regular / meals) + '/meal';

    /* CTA */
    var ctaPrice = state.plan === 'sub' ? first : regular;
    var ctaTxt   = document.getElementById('fdr32ozCtaText');
    var atcTxt   = document.getElementById('t32AtcBtnText');
    var label    = state.plan === 'sub' ? 'Subscribe · ' + fmt(ctaPrice) : 'Buy Once · ' + fmt(ctaPrice);
    if (ctaTxt) ctaTxt.textContent = label;
    if (atcTxt) atcTxt.textContent = label;

    /* Sticky bar price */
    var atcP = document.getElementById('t32AtcPrice');
    if (atcP) atcP.textContent = fmt(ctaPrice);

    /* Update form quantity */
    var qtyInput = document.getElementById('fdr32ozQty');
    if (qtyInput) qtyInput.value = bags;

    /* Toggle selling_plan input */
    var spInput = document.getElementById('fdr32ozSellingPlan');
    if (spInput) {
      if (state.plan === 'sub' && SELLING_PLAN_ID) {
        spInput.value = SELLING_PLAN_ID;
        spInput.disabled = false;
      } else {
        spInput.value = '';
        spInput.disabled = true;
      }
    }

    /* Card active/inactive states */
    var subCard  = document.getElementById('t32SubCard');
    var onceCard = document.getElementById('t32BuyOnce');
    if (subCard) {
      subCard.classList.toggle('t32-plan-active',   state.plan === 'sub');
      subCard.classList.toggle('t32-plan-inactive', state.plan !== 'sub');
    }
    if (onceCard) {
      onceCard.classList.toggle('t32-plan-active', state.plan === 'once');
    }
  }

  /* ── Plan toggle ── */
  window.t32SetPlan = function(plan) {
    state.plan = plan;
    render();
  };

  /* ── Flavor selection ── */
  function bindFlavorBtns() {
    var flavorBtns = document.querySelectorAll(SECTION_SEL + '.t32-flavor-btn');
    var variantInput = document.getElementById('fdr32ozVariantId');

    flavorBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        flavorBtns.forEach(function(b) { b.classList.remove('t32-active'); });
        this.classList.add('t32-active');

        state.flavor = this.getAttribute('data-flavor');

        /* Update variant input */
        var vid = this.getAttribute('data-variant-id');
        if (variantInput && vid) variantInput.value = vid;

        /* Sync URL */
        if (vid && window.history && window.history.replaceState) {
          var url = new URL(window.location);
          url.searchParams.set('variant', vid);
          window.history.replaceState({}, '', url);
        }

        /* Go to variant image slide */
        var imgId = this.getAttribute('data-image-id');
        if (imgId) {
          var matchSlide = document.querySelector(SECTION_SEL + '.t16-slide[data-image-id="' + imgId + '"]');
          if (matchSlide) goTo(parseInt(matchSlide.getAttribute('data-slide') || '0', 10), true);
        }

        /* Sync sticky bar flavor pills */
        document.querySelectorAll(SECTION_SEL + '.t16-atc-fpill').forEach(function(p) {
          p.classList.toggle('active', p.getAttribute('data-flavor') === state.flavor);
        });

        /* Sync feeding guide tab to flavor */
        fgFlavor = state.flavor;
        var tabs = document.querySelectorAll(SECTION_SEL + '.t32-fg-tab');
        tabs.forEach(function(t) { t.classList.toggle('t32-active', t.getAttribute('onclick') && t.getAttribute('onclick').indexOf("'" + fgFlavor + "'") > -1); });
        renderFG();
      });
    });
  }

  /* ── Age selection ── */
  function bindAgeBtns() {
    var ageBtns = document.querySelectorAll(SECTION_SEL + '.t32-age-btn');
    ageBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        ageBtns.forEach(function(b) { b.classList.remove('t32-active'); });
        this.classList.add('t32-active');
        state.age = this.getAttribute('data-age');

        var xlBtn = document.querySelector(SECTION_SEL + '[data-size="xl"]');
        var note  = document.getElementById('t32AgeNote');
        if (state.age === 'puppy') {
          if (xlBtn) xlBtn.classList.add('t32-disabled');
          if (state.size === 'xl') {
            state.size = 'l';
            document.querySelectorAll(SECTION_SEL + '.t32-size-btn').forEach(function(b) { b.classList.remove('t32-active'); });
            var lBtn = document.querySelector(SECTION_SEL + '[data-size="l"]');
            if (lBtn) lBtn.classList.add('t32-active');
          }
          if (note) note.textContent = '⚡ Puppies need ~2× the portion of adults to fuel healthy growth.';
        } else {
          if (xlBtn) xlBtn.classList.remove('t32-disabled');
          if (note) note.textContent = '';
        }
        render();
      });
    });
  }

  /* ── Size selection ── */
  function bindSizeBtns() {
    var sizeBtns = document.querySelectorAll(SECTION_SEL + '.t32-size-btn');
    sizeBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (this.classList.contains('t32-disabled')) return;
        sizeBtns.forEach(function(b) { b.classList.remove('t32-active'); });
        this.classList.add('t32-active');
        state.size = this.getAttribute('data-size');
        render();
      });
    });
  }

  /* ── Sticky bar flavor pills ── */
  function bindAtcFlavors() {
    var atcPills = document.querySelectorAll(SECTION_SEL + '.t16-atc-fpill');
    var variantInput = document.getElementById('fdr32ozVariantId');
    atcPills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        var flavor = this.getAttribute('data-flavor');
        var vid    = this.getAttribute('data-variant-id');
        /* Mirror to main flavor row */
        document.querySelectorAll(SECTION_SEL + '.t32-flavor-btn').forEach(function(b) {
          b.classList.toggle('t32-active', b.getAttribute('data-flavor') === flavor);
        });
        atcPills.forEach(function(p) { p.classList.toggle('active', p.getAttribute('data-flavor') === flavor); });
        state.flavor = flavor;
        if (variantInput && vid) variantInput.value = vid;
      });
    });

    /* Sticky ATC btn submits the form */
    var atcBtn = document.getElementById('fdr32ozAtcBtn');
    if (atcBtn) {
      atcBtn.addEventListener('click', function() {
        var form = document.getElementById('fdr-32oz-hero-atc-form');
        if (form) form.requestSubmit ? form.requestSubmit() : form.submit();
      });
    }
  }

  /* ── Carousel ── */
  var slides = document.querySelectorAll(SECTION_SEL + '.t16-slide');
  var thumbs = document.querySelectorAll(SECTION_SEL + '.t16-thumb');
  var TOTAL  = slides.length;
  var cur    = 0;
  var timer;

  function goTo(n, userTriggered) {
    cur = (n + TOTAL) % TOTAL;
    slides.forEach(function(el, i) { el.classList.toggle('t16-is-active', i === cur); });
    thumbs.forEach(function(el, i) {
      el.classList.toggle('t16-is-active', i === cur);
      if (i === cur && userTriggered) {
        var strip = document.querySelector(SECTION_SEL + '#fdr32ozThumbStrip');
        if (!strip) return;
        strip.scrollTo({ left: el.offsetLeft - (strip.clientWidth - el.offsetWidth) / 2, behavior: 'smooth' });
      }
    });
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(function() { goTo(cur + 1, false); }, 7500);
  }

  thumbs.forEach(function(thumb, i) {
    thumb.addEventListener('click', function(e) {
      e.preventDefault(); goTo(i, true); resetTimer();
    });
  });

  /* ── Sticky ATC visibility ── */
  (function() {
    var buyBox = document.getElementById('buy-box-32oz');
    var atcBar = document.getElementById('fdr32ozAtcBar');
    if (!buyBox || !atcBar) return;
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        atcBar.classList.toggle('t16-atc-visible', !entry.isIntersecting);
      });
    }, { threshold: 0.05 });
    io.observe(buyBox);
  })();

  /* ── FAQ accordion ── */
  document.querySelectorAll(SECTION_SEL + '.t16-faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item   = this.closest('.t16-faq-item');
      var isOpen = item.classList.contains('t16-is-open');
      document.querySelectorAll(SECTION_SEL + '.t16-faq-item').forEach(function(i) {
        i.classList.remove('t16-is-open');
        var b = i.querySelector('.t16-faq-btn');
        if (b) b.setAttribute('aria-expanded', 'false');
        var body = i.querySelector('.t16-faq-body');
        if (body) body.style.maxHeight = '0';
      });
      if (!isOpen) {
        item.classList.add('t16-is-open');
        btn.setAttribute('aria-expanded', 'true');
        var body = item.querySelector('.t16-faq-body');
        if (body) body.style.maxHeight = item.querySelector('.t16-faq-body-inner').scrollHeight + 'px';
      }
    });
  });

  /* ── Feeding guide ── */
  function renderFG() {
    var rows  = FG_DATA[fgFlavor] || FG_DATA.chicken;
    var tbody = document.getElementById('t32FGBody');
    if (!tbody) return;
    tbody.innerHTML = rows.map(function(r) {
      var wt = r[0], ac = r[1], ab = r[2], pc = r[3], pb = r[4], flag = r[5];
      var hl = flag === 'hl' ? ' class="t32-hl"' : '';
      var puppyCols;
      if (pc === 'max') {
        puppyCols = '<td class="t32-td-na" colspan="2">puppies: max 60 lbs</td>';
      } else if (pc === null || pc === undefined) {
        puppyCols = '<td class="t32-td-na" colspan="2">—</td>';
      } else {
        puppyCols = '<td>' + pc + '</td><td>' + pb + '</td>';
      }
      return '<tr' + hl + '><td>' + wt + '</td><td class="t32-td-adult">' + ac + '</td><td class="t32-td-adult">' + ab + '</td>' + puppyCols + '</tr>';
    }).join('');
  }

  window.t32ToggleFG = function(btn) {
    var panel = document.getElementById('t32FGPanel');
    var open  = panel.classList.toggle('t32-open');
    btn.textContent = open ? 'Hide Feeding Guide' : 'Feeding Guide';
    if (open) renderFG();
  };

  window.t32SetFGTab = function(flavor, btn) {
    document.querySelectorAll(SECTION_SEL + '.t32-fg-tab').forEach(function(t) { t.classList.remove('t32-active'); });
    btn.classList.add('t32-active');
    fgFlavor = flavor;
    renderFG();
  };

  /* ── Init ── */
  bindFlavorBtns();
  bindAgeBtns();
  bindSizeBtns();
  bindAtcFlavors();
  resetTimer();
  render();
})();
</script>

