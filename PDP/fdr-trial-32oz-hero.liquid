          <button class="t16-thumb" data-slide="{{ thumb_index }}" aria-label="Replaces 9 Supplements">
            <img src="https://cdn.shopify.com/s/files/1/0015/5919/9790/files/replace9supps.png?v=1774970809" alt="Replaces 9 Supplements" width="62" height="62" loading="lazy">
