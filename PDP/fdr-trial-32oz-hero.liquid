        </div>
        <div class="t32-benefits">
          <div class="t32-benefit"><div class="t32-bdot">✓</div><span>Best Value: <span class="t32-hl">50% off your first order</span></span></div>
          <div class="t32-benefit"><div class="t32-bdot">✓</div><span>Flexible: <span class="t32-hl">Pause, edit, or cancel anytime</span></span></div>
          <div class="t32-benefit"><div class="t32-bdot">✓</div><span>Risk Free: <span class="t32-hl">30-day money back guarantee</span></span></div>
          <div class="t32-benefit"><div class="t32-bdot">✓</div><span><b>New customers only</b></span></div>
        </div>
      </div>

      {%- comment -%} Buy once {%- endcomment -%}
      <div class="t32-buy-once" id="t32BuyOnce" onclick="t32SetPlan('once')">
        <div class="t32-buy-once-left">
          <div class="t32-radio-empty"></div>
          <span class="t32-buy-once-label">Buy Once</span>
        </div>
        <div class="t32-buy-once-right">
          <span class="t32-buy-once-price" id="t32OncePriceAmt">—</span>
          <span class="t32-buy-once-meal" id="t32OnceMeal"></span>
        </div>
      </div>

      {%- if stock_text != blank -%}
        <div class="t16-stock-alert">
          <span class="t16-stock-dot"></span>
          <span>{{ stock_text }}</span>
