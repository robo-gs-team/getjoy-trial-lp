            <div class="t32-flavor-circle">
              {%- if variant.option1 == 'Beef' -%}
                <img src="https://getjoyfood.com/cdn/shop/files/beef_e086530b-834d-489c-b5a8-5e7e0e7fdf63.svg?v=10005116391183757552" alt="Beef">
              {%- elsif variant.option1 == 'Chicken' -%}
