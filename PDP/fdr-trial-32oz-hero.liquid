{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign proof_text = section.settings.proof_text
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subtitle = section.settings.subtitle
  assign pitch = section.settings.pitch
  assign step_1_label = section.settings.step_1_label
  assign step_2_label = section.settings.step_2_label
  assign cta_text = section.settings.cta_text
  assign guarantee_text = section.settings.guarantee_text
  assign price_note = section.settings.price_note
  assign stock_text = section.settings.stock_text
  assign si_eyebrow = section.settings.si_eyebrow
  assign si_headline = section.settings.si_headline
  assign si_sub = section.settings.si_sub
  assign si_link_text = section.settings.si_link_text
  assign si_link_url = section.settings.si_link_url
  assign guarantee_shield_image = section.settings.guarantee_shield_image
  assign infographic_slide_index = section.settings.infographic_slide_position | minus: 1
  assign selling_plan_id = section.settings.selling_plan_id
-%}

{{ 'fdr-trial-pdp.css' | asset_url | stylesheet_tag }}

<style>
/* ─── HERO GRID ─── */
.t16-hero { background:var(--fdr-cream); width:100%; padding:0; }
.t16-hero-inner {
  display:grid; grid-template-columns:1fr 520px; gap:48px;
  max-width:1280px; margin:0 auto; padding:20px 40px;
  align-items:flex-start; min-height:88vh; box-sizing:border-box;
}

/* ══════════════════════════════
   LEFT  —  IMAGE CAROUSEL
══════════════════════════════ */
.t16-carousel-col {
  background:transparent; display:flex; flex-direction:column;
  border-radius:20px; overflow:visible; position:sticky; top:20px;
  max-width:560px; flex-shrink:0;
}
.t16-slide-window { width:100%; aspect-ratio:1/1; flex-shrink:0; position:relative; overflow:hidden; }
.t16-slide {
  position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  padding:0; opacity:0; transition:opacity .4s ease; pointer-events:none;
}
.t16-slide.t16-is-active { opacity:1; pointer-events:auto; }
.t16-slide img { width:100%; height:100%; object-fit:contain; border-radius:8px; }
.t16-slide-info {
  width:100%; height:100%; overflow-y:auto; background:var(--fdr-forest); border-radius:8px;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:clamp(24px,4%,48px) clamp(20px,5%,44px); box-sizing:border-box; text-align:center;
}
.t16-si-eyebrow {
  font-family:var(--fdr-font-body); font-weight:700; font-size:9px;
  letter-spacing:0.16em; text-transform:uppercase; color:var(--fdr-tennis); margin-bottom:8px;
}
.t16-si-headline {
  font-family:var(--fdr-font-heading); font-weight:900; font-size:clamp(22px,3.2vw,36px);
  color:#fff; letter-spacing:-0.03em; line-height:1.1; margin-bottom:6px;
}
.t16-si-sub {
  font-family:var(--fdr-font-serif); font-style:italic; font-size:clamp(11px,1.1vw,14px);
  color:rgba(255,255,255,.55); margin-bottom:clamp(12px,2%,24px); line-height:1.5;
}
.t16-si-hr { width:80%; max-width:320px; height:1px; background:rgba(255,255,255,.10); border:none; margin:0 auto clamp(10px,1.5%,18px); }
.t16-si-list {
  display:grid; grid-template-columns:1fr 1fr; gap:clamp(5px,0.8%,10px) clamp(8px,2%,20px);
  text-align:left; margin-bottom:clamp(10px,1.5%,18px); width:100%; max-width:380px;
}
.t16-si-item {
  display:flex; align-items:center; gap:6px; font-family:var(--fdr-font-body);
  font-size:clamp(10px,1vw,13px); color:rgba(255,255,255,.88); line-height:1.3;
}
.t16-si-check {
  width:clamp(16px,1.4vw,20px); height:clamp(16px,1.4vw,20px); background:var(--fdr-tennis);
  color:var(--fdr-forest); border-radius:50%; display:inline-flex; align-items:center;
  justify-content:center; font-weight:700; font-size:clamp(9px,.9vw,12px); flex-shrink:0; line-height:1;
}
.t16-si-summary {
  width:80%; max-width:340px; border:1px solid rgba(255,255,255,.12);
  border-radius:var(--fdr-radius); overflow:hidden; margin-bottom:clamp(8px,1%,14px);
}
.t16-si-sum-row {
  display:flex; justify-content:space-between; align-items:center;
  padding:clamp(8px,1%,12px) clamp(12px,2%,20px); font-family:var(--fdr-font-body);
  font-size:clamp(11px,1vw,13px); color:rgba(255,255,255,.50);
}
.t16-si-sum-row:first-child { border-bottom:1px solid rgba(255,255,255,.10); background:rgba(255,255,255,.04); }
.t16-si-sum-row:last-child { background:rgba(255,255,255,.08); color:#fff; }
.t16-si-sum-val { font-family:var(--fdr-font-heading); font-weight:900; font-size:clamp(12px,1.1vw,14px); letter-spacing:0.06em; text-transform:uppercase; }
.t16-si-sum-row:last-child .t16-si-sum-val { color:var(--fdr-tennis); }
.t16-si-link {
  font-family:var(--fdr-font-body); font-size:clamp(10px,.9vw,12px); color:var(--fdr-tennis);
  font-weight:600; text-decoration:underline; text-underline-offset:3px;
  text-decoration-color:rgba(195,245,74,.4); opacity:.85;
}
.t16-si-link:hover { opacity:1; text-decoration-color:var(--fdr-tennis); }

/* Thumbnail strip */
.t16-thumb-strip {
  display:flex; flex-direction:row; gap:8px; flex-shrink:0; padding:6px 12px 10px;
  background:transparent; overflow-x:auto; overflow-y:hidden; scrollbar-width:none;
}
.t16-thumb-strip::-webkit-scrollbar { display:none; }
.t16-thumb {
  flex-shrink:0; width:76px; height:76px; display:flex; align-items:center; justify-content:center;
  border:2px solid transparent; border-radius:10px; background:#fff; padding:5px; transition:border-color .18s; cursor:pointer;
}
.t16-thumb:hover { border-color:var(--fdr-forest); }
.t16-thumb.t16-is-active { border-color:var(--fdr-forest); }
.t16-thumb img { width:62px; height:62px; object-fit:cover; border-radius:6px; }
.t16-thumb span { font-size:9px; font-weight:800; letter-spacing:.8px; text-transform:uppercase; color:var(--fdr-forest); text-align:center; line-height:1.2; }

/* ══════════════════════════════
   RIGHT  —  BUY BOX
══════════════════════════════ */
.t16-buy-col { display:flex; flex-direction:column; justify-content:flex-start; padding:20px 0; overflow-y:auto; }

/* Proof bar */
.t16-proof-bar { display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding-bottom:0; margin-bottom:12px; }
.t16-stars { color:var(--fdr-amber); font-size:14px; letter-spacing:2px; line-height:1; flex-shrink:0; }
.t16-proof-dot { color:var(--fdr-muted); font-size:14px; flex-shrink:0; }
.t16-proof-stat { font-family:var(--fdr-font-body); font-weight:700; font-size:14px; color:var(--fdr-forest); white-space:nowrap; flex-shrink:0; }

/* Title */
.t16-product-h1 { display:flex; flex-direction:column; gap:2px; color:var(--fdr-forest); letter-spacing:-1px; line-height:1.05; margin-bottom:6px; }
.t16-product-h1-offer { font-size:13px; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:var(--fdr-muted); }
.t16-product-h1-value { font-size:36px; font-weight:900; font-family:var(--fdr-font-heading); letter-spacing:-1.5px; color:var(--fdr-forest); line-height:1.0; }
.t16-product-sub { font-size:12px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:var(--fdr-muted); margin-bottom:8px; }
.t16-product-pitch { font-family:var(--fdr-font-serif); font-style:italic; font-weight:300; font-size:15.5px; color:var(--fdr-muted); line-height:1.6; margin-bottom:22px; max-width:400px; }
.t16-product-pitch p { margin:0; }

/* Field label */
.t16-field-label {
  font-size:10px; font-weight:800; letter-spacing:2px; text-transform:uppercase;
  color:var(--fdr-muted); margin-bottom:9px; display:flex; align-items:center; gap:8px;
}
.t16-field-label::after { content:''; flex:1; height:1px; background:var(--fdr-rule); }

/* Stock alert */
.t16-stock-alert {
  display:flex; align-items:center; gap:8px; font-size:12px; color:var(--fdr-muted);
  font-weight:600; margin-bottom:14px; margin-top:6px;
}
.t16-stock-dot { width:7px; height:7px; border-radius:50%; background:#E55000; flex-shrink:0; animation:t16-pulse-dot 1.6s ease-in-out infinite; }
@keyframes t16-pulse-dot { 0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)} }

/* CTA */
.t16-cta-main {
  width:100%; background:var(--fdr-green); color:#fff; font-family:var(--fdr-font-heading);
  font-weight:900; font-size:17px; text-transform:uppercase; letter-spacing:-.5px;
  padding:18px 22px; border-radius:100px; border:none; display:flex; align-items:center;
  justify-content:center; text-align:center; transition:all .25s; margin-bottom:10px;
  position:relative; overflow:hidden; cursor:pointer;
}
.t16-cta-main::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,.1) 0%,transparent 55%); pointer-events:none; }
.t16-cta-main:hover { background:var(--fdr-forest); transform:translateY(-2px); }
.t16-cta-arrow { display:inline-block; vertical-align:middle; margin-left:7px; flex-shrink:0; position:relative; top:-1px; }

/* Guarantee */
.t16-guarantee {
  display:flex; align-items:center; gap:11px; background:var(--fdr-pale);
  border:1.5px solid rgba(0,204,59,.25); border-radius:var(--fdr-radius); padding:12px 14px;
}
.t16-g-mark { width:34px; height:34px; object-fit:contain; flex-shrink:0; }
.t16-g-text b { display:block; font-size:13px; font-weight:700; color:var(--fdr-forest); margin-bottom:2px; }
.t16-g-text p { font-size:11px; color:var(--fdr-muted); line-height:1.4; }

/* FAQ Accordion */
.t16-faq { margin-top:16px; }
.t16-faq--buy { display:none; }
.t16-faq-item { border:1.5px solid var(--fdr-rule); border-radius:var(--fdr-radius); background:var(--fdr-cream); overflow:hidden; transition:border-color .2s; }
.t16-faq-item + .t16-faq-item { margin-top:6px; }
.t16-faq-item.t16-is-open { border-color:var(--fdr-forest); }
.t16-faq-btn { width:100%; display:flex; align-items:center; justify-content:space-between; gap:12px; padding:13px 16px; background:transparent; border:none; font-family:var(--fdr-font-body); font-size:13.5px; font-weight:700; color:var(--fdr-ink); text-align:left; cursor:pointer; }
.t16-faq-chevron { flex-shrink:0; width:18px; height:18px; color:var(--fdr-forest); transition:transform .25s ease; }
.t16-faq-item.t16-is-open .t16-faq-chevron { transform:rotate(180deg); }
.t16-faq-body { max-height:0; overflow:hidden; transition:max-height .3s ease; }
.t16-faq-body-inner { padding:0 16px 14px; font-size:13px; line-height:1.65; color:var(--fdr-muted); }
.t16-faq-body-inner a { color:var(--fdr-forest); font-weight:700; }

/* ─── STICKY ATC BAR ─── */
.t16-atc-bar {
  position:fixed; bottom:0; left:0; right:0; z-index:999; background:var(--fdr-forest);
  border-top:1px solid rgba(255,255,255,0.10); box-shadow:0 -4px 24px rgba(0,0,0,0.20);
  padding-bottom:env(safe-area-inset-bottom); opacity:0; transform:translateY(100%);
  transition:opacity .25s ease, transform .25s ease; pointer-events:none;
}
.t16-atc-bar.t16-atc-visible { opacity:1; transform:translateY(0); pointer-events:auto; }
.t16-atc-inner { max-width:1100px; margin:0 auto; padding:0 32px; height:82px; display:flex; align-items:center; justify-content:space-between; gap:16px; }
.t16-atc-left { flex:0 0 auto; display:flex; align-items:center; gap:12px; min-width:0; }
.t16-atc-spacer { flex:1; }
.t16-atc-icon { width:36px; height:36px; flex-shrink:0; object-fit:contain; }
.t16-atc-text { min-width:0; }
.t16-atc-name { font-family:var(--fdr-font-heading); font-weight:900; font-size:14px; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.t16-atc-name-price { font-family:var(--fdr-font-heading); font-weight:700; font-size:14px; color:rgba(255,255,255,0.80); }
.t16-atc-desc { font-family:var(--fdr-font-body); font-weight:400; font-size:12px; color:rgba(255,255,255,0.50); white-space:nowrap; }
.t16-atc-btn { flex-shrink:0; background:var(--fdr-green); color:#fff; border:none; border-radius:100px; font-family:var(--fdr-font-body); font-weight:800; font-size:14px; letter-spacing:0.02em; padding:14px 28px; white-space:nowrap; cursor:pointer; transition:background .15s ease; }
.t16-atc-btn:hover { background:#00b534; }
.t16-atc-btn-m { display:none; }
.t16-atc-flavors { flex-shrink:0; display:flex; flex-direction:row; align-items:center; gap:6px; }
.t16-atc-fpill { display:inline-flex; align-items:center; gap:5px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.18); border-radius:100px; padding:5px 10px; font-family:var(--fdr-font-body); font-weight:600; font-size:11px; color:rgba(255,255,255,.55); cursor:pointer; white-space:nowrap; transition:all .15s ease; }
.t16-atc-fpill.active { background:rgba(255,255,255,.15); border-color:rgba(255,255,255,.60); color:#fff; }
.t16-atc-fdot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

/* ── RESPONSIVE ── */
@media(max-width:960px) {
  .t16-hero-inner { grid-template-columns:1fr; padding:0 16px 32px; gap:0; min-height:auto; }
  .t16-carousel-col { position:relative; height:auto; border-radius:0; top:0; border-bottom:1px solid var(--fdr-rule); min-width:0; max-width:100%; }
  .t16-buy-col { max-width:100%; padding:24px 0 0 0; }
  .t16-faq--carousel { display:none; }
  .t16-faq--buy { display:block; }
  .t16-slide-window { flex:none; width:100%; height:100vw; max-height:100vw; min-height:unset; }
  .t16-thumb-strip { padding:10px 12px 12px; }
  .t16-thumb { width:70px; height:70px; padding:6px; }
  .t16-thumb img { width:54px; height:54px; }
  .t16-product-h1 { order:-3; }
  .t16-product-sub { order:-2; }
  .t16-proof-bar { order:-1; margin-top:10px; margin-bottom:10px; }
  .t16-product-pitch { margin-top:8px; }
}
@media(max-width:640px) {
  .t16-atc-inner { height:auto; padding:10px 16px 12px; display:flex; align-items:center; justify-content:space-between; gap:10px; width:100%; box-sizing:border-box; }
  .t16-atc-left { display:none; }
  .t16-atc-spacer { display:none; }
  .t16-atc-flavors { flex-direction:column; gap:5px; flex-shrink:0; }
  .t16-atc-fpill { font-size:11px; padding:5px 10px; min-width:80px; }
  .t16-atc-btn { flex:none; border-radius:100px; font-size:13px; padding:12px 16px; text-align:center; white-space:nowrap; display:block; }
  .t16-atc-btn-d { display:none; }
  .t16-atc-btn-m { display:inline; }
}
@media(min-width:641px) and (max-width:960px) { .t16-atc-desc { display:none; } }

/* ══════════════════════════════
   SUBSCRIPTION SELECTOR
══════════════════════════════ */

/* Flavor circles */
.t32-flavor-row { display:flex; gap:14px; margin-bottom:20px; }
.t32-flavor-btn { display:flex; flex-direction:column; align-items:center; gap:5px; cursor:pointer; background:none; border:none; padding:0; }
.t32-flavor-circle {
  width:54px; height:54px; border-radius:50%; background:#C8D8DC;
  display:flex; align-items:center; justify-content:center;
  border:3px solid transparent; transition:background .15s;
}
.t32-flavor-circle img { width:28px; height:28px; object-fit:contain; opacity:.45; transition:opacity .15s; }
.t32-flavor-btn.t32-active .t32-flavor-circle { background:#F5A623; }
.t32-flavor-btn.t32-active .t32-flavor-circle img { opacity:1; }
.t32-flavor-label { font-size:12px; font-weight:600; color:var(--fdr-ink); font-family:var(--fdr-font-body); }

/* Life stage */
.t32-age-row { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:6px; }
.t32-age-btn {
  padding:10px 6px; border:1.5px solid rgba(0,80,5,.18); border-radius:8px;
  background:#fff; cursor:pointer; font-size:13px; font-weight:700;
  color:var(--fdr-ink); text-align:center; line-height:1.3; font-family:var(--fdr-font-body);
  transition:background .15s, border-color .15s, color .15s;
}
.t32-age-btn .t32-age-sub { display:block; font-size:11px; font-weight:400; color:var(--fdr-muted); margin-top:2px; }
.t32-age-btn.t32-active { background:var(--fdr-forest); border-color:var(--fdr-forest); color:#fff; }
.t32-age-btn.t32-active .t32-age-sub { color:rgba(255,255,255,.7); }
.t32-age-note { font-size:11px; color:var(--fdr-muted); min-height:16px; margin-bottom:14px; }

/* Dog size swatches */
.t32-size-row { display:grid; grid-template-columns:repeat(5,1fr); gap:6px; margin-bottom:8px; }
.t32-size-btn {
  padding:10px 4px; border:1.5px solid rgba(0,80,5,.18); border-radius:8px;
  background:#fff; cursor:pointer; font-size:10px; font-weight:700;
  color:var(--fdr-ink); text-align:center; line-height:1.35; font-family:var(--fdr-font-body);
  transition:background .15s, border-color .15s, color .15s;
}
.t32-size-btn.t32-active { background:var(--fdr-forest); border-color:var(--fdr-forest); color:#fff; }
.t32-size-btn.t32-disabled { opacity:.35; cursor:not-allowed; pointer-events:none; }
.t32-size-meta { font-size:12px; color:var(--fdr-muted); margin-bottom:2px; text-align:left; min-height:18px; }
.t32-meal-disc { font-size:10px; color:var(--fdr-muted); opacity:.75; margin-bottom:6px; line-height:1.4; }

/* Feeding guide */
.t32-fg-row { margin-bottom:14px; }
.t32-fg-row button { background:none; border:none; font-size:13px; color:var(--fdr-forest); text-decoration:underline; cursor:pointer; font-family:var(--fdr-font-body); font-weight:500; padding:0; }
.t32-fg-panel { display:none; border:1px solid rgba(0,80,5,.18); border-radius:10px; overflow:hidden; margin-bottom:16px; background:#fff; }
.t32-fg-panel.t32-open { display:block; }
.t32-fg-note { font-size:11px; color:var(--fdr-muted); padding:10px 14px; border-bottom:1px solid rgba(0,80,5,.1); font-style:italic; }
.t32-fg-tabs { display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid rgba(0,80,5,.1); }
.t32-fg-tab { padding:9px; text-align:center; font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; cursor:pointer; background:none; border:none; font-family:var(--fdr-font-body); color:var(--fdr-muted); transition:background .15s, color .15s; }
.t32-fg-tab.t32-active { background:var(--fdr-forest); color:#fff; }
.t32-fg-table-wrap { overflow-x:auto; }
.t32-fg-table { width:100%; border-collapse:collapse; font-size:11px; font-family:var(--fdr-font-body); }
.t32-fg-table thead tr { background:rgba(232,223,201,.5); }
.t32-fg-table thead th { padding:8px 10px; text-align:center; font-size:10px; font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:var(--fdr-muted); border-bottom:1px solid rgba(0,80,5,.12); }
.t32-fg-table thead th.t32-col-adult { color:var(--fdr-forest); }
.t32-fg-table thead th:first-child { text-align:left; }
.t32-fg-table tbody tr { border-bottom:1px solid rgba(0,80,5,.07); }
.t32-fg-table tbody tr:last-child { border-bottom:none; }
.t32-fg-table tbody tr.t32-hl { background:rgba(0,80,5,.04); }
.t32-fg-table tbody td { padding:7px 10px; text-align:center; color:var(--fdr-muted); }
.t32-fg-table tbody td:first-child { text-align:left; font-weight:600; color:var(--fdr-ink); }
.t32-fg-table .t32-td-adult { color:var(--fdr-forest); }
.t32-fg-table .t32-td-na { color:var(--fdr-muted); opacity:.6; font-size:10px; }

/* Subscribe / Buy-once cards */
.t32-sub-card {
  background:#fff; border:1.5px solid rgba(0,80,5,.18); border-radius:12px;
  padding:14px 16px; margin-bottom:10px; cursor:pointer;
  transition:border-color .15s;
}
.t32-sub-card.t32-plan-active { border-color:var(--fdr-forest); }
.t32-sub-card.t32-plan-inactive { opacity:.55; }
.t32-sub-card.t32-plan-inactive .t32-radio-filled { border-color:var(--fdr-muted); }
.t32-sub-card.t32-plan-inactive .t32-radio-filled::after { background:transparent; }

.t32-card-top { display:flex; align-items:flex-start; gap:10px; margin-bottom:12px; }
.t32-radio-filled { width:18px; height:18px; border-radius:50%; border:2px solid var(--fdr-forest); display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }
.t32-radio-filled::after { content:''; width:8px; height:8px; border-radius:50%; background:var(--fdr-forest); }
.t32-title-wrap { flex:1; }
.t32-card-title { font-size:14px; font-weight:800; color:var(--fdr-ink); line-height:1.3; font-family:var(--fdr-font-body); }
.t32-card-sub { font-size:11px; font-weight:500; color:var(--fdr-muted); margin-top:2px; line-height:1.35; font-family:var(--fdr-font-body); }
.t32-best-badge { background:var(--fdr-tennis); color:#1a4d1f; font-size:10px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; padding:3px 7px; border-radius:4px; white-space:nowrap; flex-shrink:0; align-self:flex-start; }

.t32-freq-row { display:flex; align-items:center; margin-left:28px; margin-bottom:12px; }
.t32-freq-static { font-size:12px; font-weight:500; color:var(--fdr-muted); font-family:var(--fdr-font-body); }
.t32-price-right { margin-left:auto; text-align:right; }
.t32-price-now { font-size:16px; font-weight:800; color:var(--fdr-forest); }
.t32-price-was { font-size:13px; color:var(--fdr-muted); text-decoration:line-through; margin-left:3px; }
.t32-price-meal { display:block; font-size:11px; color:var(--fdr-muted); margin-top:1px; }

.t32-benefits { margin-left:28px; display:flex; flex-direction:column; gap:5px; }
.t32-benefit { display:flex; align-items:center; gap:7px; font-size:12px; color:var(--fdr-muted); line-height:1.3; font-family:var(--fdr-font-body); }
.t32-bdot { width:14px; height:14px; border-radius:50%; background:var(--fdr-forest); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:8px; color:#fff; font-weight:900; }
.t32-benefit .t32-hl { color:var(--fdr-forest); font-weight:600; }

/* Buy once */
.t32-buy-once {
  background:#fff; border:1.5px solid rgba(0,80,5,.12); border-radius:12px;
  padding:14px 16px; display:flex; align-items:center; justify-content:space-between;
  margin-bottom:14px; cursor:pointer; transition:border-color .15s;
}
.t32-buy-once.t32-plan-active { border-color:var(--fdr-forest); }
.t32-buy-once-left { display:flex; align-items:center; gap:10px; }
.t32-radio-empty { width:18px; height:18px; border-radius:50%; border:2px solid var(--fdr-muted); flex-shrink:0; position:relative; }
.t32-buy-once.t32-plan-active .t32-radio-empty { border-color:var(--fdr-forest); }
.t32-buy-once.t32-plan-active .t32-radio-empty::after { content:''; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:8px; height:8px; border-radius:50%; background:var(--fdr-forest); }
.t32-buy-once-label { font-size:14px; color:var(--fdr-muted); font-weight:500; font-family:var(--fdr-font-body); }
.t32-buy-once-right { text-align:right; }
.t32-buy-once-price { display:block; font-size:14px; font-weight:700; color:var(--fdr-muted); }
.t32-buy-once-meal { display:block; font-size:11px; color:var(--fdr-muted); opacity:.7; margin-top:1px; }

/* Guarantee box */
.t32-guarantee-box { background:#DCEFC8; border:1px solid #B8DA9E; border-radius:10px; padding:10px 14px; margin-top:4px; }
.t32-guarantee-title { font-size:13px; font-weight:700; color:#1a4d1f; margin-bottom:2px; font-family:var(--fdr-font-body); }
.t32-guarantee-sub { font-size:12px; color:#2a5a30; line-height:1.4; font-family:var(--fdr-font-body); }

@media(max-width:480px) {
  .t32-size-btn { font-size:9px; padding:8px 2px; }
  .t32-flavor-circle { width:46px; height:46px; }
  .t32-flavor-circle img { width:22px; height:22px; }
}
</style>

<section class="t16-hero" id="hero">
  <div class="t16-hero-inner">

    {%- comment -%} ===== LEFT: CAROUSEL ===== {%- endcomment -%}
    <div class="t16-carousel-col">

      <div class="t16-slide-window" id="fdr32ozSlideWindow">
        {%- assign slide_index = 0 -%}
        {%- for image in product.images -%}
          {%- if slide_index == infographic_slide_index -%}
            <div class="t16-slide{% if infographic_slide_index == 0 %} t16-is-active{% endif %}" data-slide="{{ infographic_slide_index }}">
              <div class="t16-slide-info">
                {%- if si_eyebrow != blank -%}<p class="t16-si-eyebrow">{{ si_eyebrow }}</p>{%- endif -%}
                {%- if si_headline != blank -%}<h3 class="t16-si-headline">{{ si_headline }}</h3>{%- endif -%}
                {%- if si_sub != blank -%}<p class="t16-si-sub">{{ si_sub }}</p>{%- endif -%}
                <hr class="t16-si-hr">
                <div class="t16-si-list">
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'supplement_item' -%}
                      <div class="t16-si-item" {{ block.shopify_attributes }}><span class="t16-si-check">&#x2713;</span> {{ block.settings.label }}</div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <hr class="t16-si-hr">
                <div class="t16-si-summary">
                  <div class="t16-si-sum-row"><span>Your supplement cabinet</span><span class="t16-si-sum-val">9 Products</span></div>
                  <div class="t16-si-sum-row"><span><strong>Get Joy</strong></span><span class="t16-si-sum-val">1 Bag</span></div>
                </div>
                {%- if si_link_text != blank -%}<a class="t16-si-link" href="{{ si_link_url | default: '#ingredients-section' }}">{{ si_link_text }}</a>{%- endif -%}
              </div>
            </div>
            {%- assign slide_index = slide_index | plus: 1 -%}
          {%- endif -%}

          <div class="t16-slide{% if slide_index == 0 %} t16-is-active{% endif %}" data-slide="{{ slide_index }}" data-image-id="{{ image.id }}">
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              width="800" height="800"
              {% if slide_index == 0 %}loading="eager"{% else %}loading="lazy"{% endif %}
            >
          </div>
          {%- assign slide_index = slide_index | plus: 1 -%}
        {%- endfor -%}

        {%- if infographic_slide_index >= product.images.size -%}
          <div class="t16-slide" data-slide="{{ slide_index }}">
            <div class="t16-slide-info">
              {%- if si_eyebrow != blank -%}<p class="t16-si-eyebrow">{{ si_eyebrow }}</p>{%- endif -%}
              {%- if si_headline != blank -%}<h3 class="t16-si-headline">{{ si_headline }}</h3>{%- endif -%}
              {%- if si_sub != blank -%}<p class="t16-si-sub">{{ si_sub }}</p>{%- endif -%}
              <hr class="t16-si-hr">
              <div class="t16-si-list">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'supplement_item' -%}
                    <div class="t16-si-item" {{ block.shopify_attributes }}><span class="t16-si-check">&#x2713;</span> {{ block.settings.label }}</div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <hr class="t16-si-hr">
              <div class="t16-si-summary">
                <div class="t16-si-sum-row"><span>Your supplement cabinet</span><span class="t16-si-sum-val">9 Products</span></div>
                <div class="t16-si-sum-row"><span><strong>Get Joy</strong></span><span class="t16-si-sum-val">1 Bag</span></div>
              </div>
              {%- if si_link_text != blank -%}<a class="t16-si-link" href="{{ si_link_url | default: '#ingredients-section' }}">{{ si_link_text }}</a>{%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Thumbnail strip {%- endcomment -%}
      <div class="t16-thumb-strip" id="fdr32ozThumbStrip">
        {%- assign thumb_index = 0 -%}
        {%- for image in product.images -%}
          {%- if thumb_index == infographic_slide_index -%}
            <button class="t16-thumb{% if infographic_slide_index == 0 %} t16-is-active{% endif %}" data-slide="{{ infographic_slide_index }}" aria-label="Replaces 9 Supplements">
              <img src="https://cdn.shopify.com/s/files/1/0015/5919/9790/files/replace9supps.png?v=1774970809" alt="Replaces 9 Supplements" width="62" height="62" loading="lazy">
            </button>
            {%- assign thumb_index = thumb_index | plus: 1 -%}
          {%- endif -%}
          <button class="t16-thumb{% if thumb_index == 0 %} t16-is-active{% endif %}" data-slide="{{ thumb_index }}" aria-label="{{ image.alt | escape | default: 'Product image' }}">
