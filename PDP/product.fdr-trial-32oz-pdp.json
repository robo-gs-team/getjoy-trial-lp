    "fdr_trial_16oz_faq_XYwijG": {
      "type": "fdr-trial-16oz-faq",
      "blocks": {
        "faq_item_thdG4q": {
          "type": "faq_item",
          "settings": {
            "question": "How do I transition my dog?",
            "answer": "<p>Start by mixing a small amount of Get Joy into your dog’s current food. Increase the ratio over 7–10 days. Most dogs make a full switch within two weeks — and most don’t need convincing. Sensitive stomachs? Take it slower. That’s it.</p>"
          }
        },
        "faq_item_kdYWWg": {
          "type": "faq_item",
          "settings": {
            "question": "What if my dog is a picky eater?",
            "answer": "<p>Freeze Dried Raw is the closest thing to whole, fresh food — which is what dogs actually want. The 221% improvement in breath and the mealtime excitement we see in our 60-day study aren’t coincidences. If your dog genuinely isn’t interested within 30 days, we refund every penny.</p>"
          }
        },
        "faq_item_U6tryk": {
          "type": "faq_item",
          "settings": {
            "question": "Will this work for my dog’s specific issue?",
            "answer": "<p>Get Joy was built around gut health — because most visible dog health problems (bad breath, dull coat, low energy, joint stiffness, anxiety) trace back to what’s happening in the gut. Belly Biotics™ addresses the root system. The ingredients target the specific symptoms. Most owners notice changes within the first week.</p>"
          }
        },
        "faq_item_LNfH3t": {
          "type": "faq_item",
          "settings": {
            "question": "Is there a subscription or commitment?",
            "answer": "<p>No subscription, no auto-ship — ever. This is a one-time purchase. Nothing starts after checkout. If you’d like to continue after trying it, you’ll have the option — but it’s entirely your call.</p>"
          }
        },
        "faq_item_dH7XcY": {
          "type": "faq_item",
          "settings": {
            "question": "How is Get Joy different from fresh cooked food like Farmer's?",
            "answer": "<p>Fresh cooked food reaches your dog’s bowl at 165°F+. Every enzyme and probiotic is destroyed above 118°F. Get Joy is freeze-dried at −40°F — 97% of nutrients intact, probiotics viable, digestive enzymes preserved. Shelf stable. No fridge required.</p>"
          }
        }
      },
